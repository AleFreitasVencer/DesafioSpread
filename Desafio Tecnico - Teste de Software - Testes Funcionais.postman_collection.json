  "item": [
    {
      "name": "CT_01 - Consulta CEP válido",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code deve ser 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test('Validar estado', function () {",
              "    pm.expect(jsonData.state).to.eql('SP');",
              "});",
              "",
              "pm.test('Validar cidade', function () {",
              "    pm.expect(jsonData.city).to.eql('Osasco');",
              "});",
              "",
              "pm.test('Validar bairro', function () {",
              "    pm.expect(jsonData.district).to.eql('Piratininga');",
              "});",
              "",
              "pm.test('Validar logradouro', function () {",
              "    pm.expect(jsonData.address).to.eql('Rua Paula Rodrigues');",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/72145-808.json",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "72145-808.json"
          ]
        }
      },
      "response": []
    },
